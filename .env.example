# ChatGPT / OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30

# Optional: local clone path of OpenClaw-Medical-Skills
OPENCLAW_SKILLS_PATH=/path/to/OpenClaw-Medical-Skills/skills

# Runtime config
TRIAGE_RULES_PATH=./configs/triage_rules.yaml
DEPARTMENTS_MAPPING_PATH=./configs/departments_mapping.yaml
RAG_SOURCES_PATH=./configs/rag_sources.yaml
KNOWLEDGE_DIR=./data/knowledge
AUDIT_LOG_PATH=./data/audit/triage_audit.jsonl
